DJANGO_SECRET_KEY=change-me-to-a-real-secret-key
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,[::1]
DJANGO_CSRF_TRUSTED_ORIGINS=

# Email settings for password reset delivery
DJANGO_EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
DJANGO_EMAIL_HOST=smtp.gmail.com
DJANGO_EMAIL_PORT=587
DJANGO_EMAIL_USE_TLS=True
DJANGO_EMAIL_USE_SSL=False
DJANGO_EMAIL_HOST_USER=venustendikumana2003@gmail.com
DJANGO_EMAIL_HOST_PASSWORD=your-gmail-app-password
DJANGO_DEFAULT_FROM_EMAIL=venustendikumana2003@gmail.com

# Password reset security controls
DJANGO_PASSWORD_RESET_TIMEOUT=3600
DJANGO_PASSWORD_RESET_THROTTLE_REQUEST_LIMIT=3
DJANGO_PASSWORD_RESET_THROTTLE_LOCKOUT_SECONDS=900